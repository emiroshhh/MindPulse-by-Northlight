# Server-only. Set exactly one provider key in Vercel.
# auto uses a configured live provider, or the safe local demo companion in development.
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
AI_MAX_TOKENS=500
AI_TIMEOUT_MS=20000
# Set true only for an explicitly labelled production demo without a provider key.
ENABLE_DEMO_AI=false

# Public Supabase project identifiers (never put a service-role key here).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated allowed mobile/web origins in production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
